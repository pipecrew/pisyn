{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "minimumReleaseAge": "24 hours",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.go$/"
      ],
      "matchStrings": [
        "//\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>.+?)\\s*\\n\\s*\\w+\\s*=\\s*\".+?:(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["go"],
      "groupName": "Go dependencies",
      "groupSlug": "go-deps"
    }
  ]
}
